# Copy this file to ".env" and fill in your own keys.
#   cp .env.example .env
# .env is git-ignored so your real keys never get committed.

# Pollination AI — image GENERATION (https://pollinations.ai)
POLLINATIONS_TOKEN=sk_your_pollinations_token_here

